{
  "name": "rovo-execution-guard",
  "version": "0.1.0",
  "private": true,
  "description": "Atlassian Forge app that validates consistency between Jira, Confluence, and GitHub using Rovo AI, blocking low-quality workflow transitions",
  "main": "src/resolver-handler.ts",
  "scripts": {
    "lint": "eslint 'src/**/*.{ts,tsx}'",
    "lint:fix": "eslint 'src/**/*.{ts,tsx}' --fix",
    "format": "prettier --write 'src/**/*.{ts,tsx,json,md}'",
    "format:check": "prettier --check 'src/**/*.{ts,tsx,json,md}'",
    "typecheck": "tsc --noEmit",
    "test:unit": "jest --passWithNoTests --config config/jest.config.js",
    "test:integration": "jest --passWithNoTests --config config/jest.integration.config.js",
    "test:staged": "jest --bail --findRelatedTests --config config/jest.config.js",
    "build:ui": "esbuild src/frontend/custom-ui/issue-panel/app.tsx --bundle --outfile=src/frontend/custom-ui/issue-panel/bundle.js --minify --format=iife --target=es2022 --jsx=automatic && esbuild src/frontend/custom-ui/admin-dashboard/app.tsx --bundle --outfile=src/frontend/custom-ui/admin-dashboard/bundle.js --minify --format=iife --target=es2022 --jsx=automatic",
    "predeploy": "pnpm build:ui",
    "deploy": "forge deploy -e kcantero",
    "prepare": "husky"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@atlaskit/button": "^23.11.3",
    "@atlaskit/checkbox": "^17.3.12",
    "@atlaskit/flag": "^17.10.0",
    "@atlaskit/range": "^10.0.7",
    "@atlaskit/section-message": "^8.12.14",
    "@atlaskit/spinner": "^19.1.2",
    "@atlaskit/textfield": "^8.3.2",
    "@atlaskit/toggle": "^15.6.0",
    "@atlaskit/tokens": "^13.0.1",
    "@forge/api": "^3.0.0",
    "@forge/bridge": "^5.15.1",
    "@forge/resolver": "^1.5.0",
    "@sentry/browser": "^10.50.0",
    "@sentry/node": "^10.50.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.0.0",
    "@commitlint/config-conventional": "^19.0.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^29.5.0",
    "@types/nock": "^11.1.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "esbuild": "^0.28.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-import-resolver-typescript": "^3.6.0",
    "eslint-plugin-react": "^7.34.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "husky": "^9.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.3.0",
    "lint-staged": "^15.2.0",
    "nock": "^14.0.13",
    "prettier": "^3.2.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.5.0"
  }
}
