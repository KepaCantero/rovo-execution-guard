{
  "name": "rovo-execution-guard",
  "version": "0.1.0",
  "private": true,
  "description": "Atlassian Forge app that validates consistency between Jira, Confluence, and GitHub using Rovo AI, blocking low-quality workflow transitions",
  "main": "src/frontend/index.jsx",
  "scripts": {
    "lint": "eslint 'src/**/*.{ts,tsx}'",
    "lint:fix": "eslint 'src/**/*.{ts,tsx}' --fix",
    "format": "prettier --write 'src/**/*.{ts,tsx,json,md}'",
    "format:check": "prettier --check 'src/**/*.{ts,tsx,json,md}'",
    "typecheck": "tsc --noEmit",
    "test:unit": "jest --passWithNoTests --config config/jest.config.js",
    "test:staged": "jest --bail --findRelatedTests --config config/jest.config.js",
    "prepare": "husky"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@forge/api": "^3.0.0",
    "@forge/react": "^10.0.0",
    "@forge/resolver": "^1.5.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.0.0",
    "@commitlint/config-conventional": "^19.0.0",
    "@testing-library/react": "^16.0.0",
    "@types/jest": "^29.5.0",
    "@types/react": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-import-resolver-typescript": "^3.6.0",
    "eslint-plugin-react": "^7.34.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "husky": "^9.0.0",
    "jest": "^29.7.0",
    "lint-staged": "^15.2.0",
    "prettier": "^3.2.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.5.0"
  }
}
