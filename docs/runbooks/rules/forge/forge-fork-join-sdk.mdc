### Rule 63: Advanced Troubleshooting

**Workflow Stuck Analysis:**
```typescript
async function analyzeStuckWorkflow(workflowId: string) {
  const workflow = await storageProvider.getWorkflowStatus(workflowId);
  const tasks = await storageProvider.getAllTasks(workflowId);
  
  const analysis = {
    workflowStatus: workflow.status,
    pendingTasks: tasks.filter(t => t.status === 'pending'),
    readyTasks: tasks.filter(t => t.status === 'ready'),
    queuedTasks: tasks.filter(t => t.status === 'queued'),
    runningTasks: tasks.filter(t => t.status === 'running'),
    failedTasks: tasks.filter(t => t.status === 'failed'),
  };
  
  // Check for issues
  if (analysis.readyTasks.length > 0 && analysis.queuedTasks.length === 0) {
    console.warn('Tasks ready but not queued - check enqueuer');
  }
  
  if (analysis.queuedTasks.length > 0) {
    console.warn('Tasks stuck in queue - check consumer');
  }
  
  return analysis;
}
```

**Dependency Analysis:**
```typescript
function analyzeDependencies(spec: WorkflowSpec) {
  const issues = [];
  
  // Check for missing dependencies
  for (const [taskId, deps] of Object.entries(spec.dependencies)) {
    for (const dep of deps) {
      if (!spec.tasks[dep]) {
        issues.push(`Task ${taskId} depends on non-existent task ${dep}`);
      }
    }
  }
  
  // Check for circular dependencies
  const visited = new Set();
  const recStack = new Set();
  
  function hasCycle(taskId: string): boolean {
    if (recStack.has(taskId)) return true;
    if (visited.has(taskId)) return false;
    
    visited.add(taskId);
    recStack.add(taskId);
    
    for (const dep of spec.dependencies[taskId] || []) {
      if (hasCycle(dep)) return true;
    }
    
    recStack.delete(taskId);
    return false;
  }
  
  for (const taskId of Object.keys(spec.tasks)) {
    if (hasCycle(taskId)) {
      issues.push(`Circular dependency detected involving ${taskId}`);
    }
  }
  
  return issues;
}
```

