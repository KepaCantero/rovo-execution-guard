### Rule 18: Retry Configuration

```typescript
const workflowSpec: WorkflowSpec = {
  tasks: {
    'fetch-data': {
      handlerName: 'fetchData',
      retryConfig: {
        maxAttempts: 3,
        backoffMs: 1000,  // Exponential backoff starting at 1 second
      },
