async function profileWorkflowExecution(workflowId: string) {
  const startTime = Date.now();
  const result = await orchestrator.executeWorkflow(workflowId);
  const endTime = Date.now();
  
  const tasks = await storageProvider.getAllTasks(workflowId);
  const taskTimings = tasks.map(t => ({
    taskId: t.taskId,
    duration: t.endTime ? 
      new Date(t.endTime).getTime() - new Date(t.startTime).getTime() : 
      null,
  }));
  
  return {
    totalDuration: endTime - startTime,
    taskTimings,
    bottlenecks: taskTimings
      .filter(t => t.duration && t.duration > 5000)
      .sort((a, b) => (b.duration || 0) - (a.duration || 0)),
  };
}
