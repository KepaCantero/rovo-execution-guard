  maxAttempts: 5,
  backoffMs: 1000,
  backoffMultiplier: 2,
  retryableErrors: [ErrorType.TRANSIENT, ErrorType.RATE_LIMIT],
  nonRetryableErrors: [ErrorType.PERMANENT, ErrorType.VALIDATION],
};
```

